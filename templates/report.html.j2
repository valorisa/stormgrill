<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
<head>
<meta charset="UTF-8">
<title>{{ title }} — StormGrill Report</title>
<style>
  :root {
    --navy: #0b1f3a;
    --orange: #e8823a;
    --cream: #f7f2e9;
    --ink: #1a1a1a;
  }
  body {
    font-family: -apple-system, "Segoe UI", sans-serif;
    background: var(--cream);
    color: var(--ink);
    margin: 0;
    padding: 0;
  }
  header {
    background: var(--navy);
    color: var(--cream);
    padding: 2rem;
  }
  header h1 { margin: 0; }
  .badge {
    display: inline-block;
    background: var(--orange);
    color: var(--navy);
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }
  main { max-width: 860px; margin: 0 auto; padding: 2rem; }
  section { margin-bottom: 2.5rem; }
  h2 { color: var(--navy); border-bottom: 2px solid var(--orange); padding-bottom: 0.3rem; }
  .reliability { font-weight: 600; color: var(--orange); }
  footer { text-align: center; padding: 2rem; color: #777; font-size: 0.85rem; }
</style>
</head>
<body>
<header>
  <span class="badge">StormGrill</span>
  <h1>{{ title }}</h1>
  <p>{{ summary_60s }}</p>
</header>
<main>
  <section id="insights">
    <h2>{{ labels.insights }}</h2>
    <!-- TODO(V0): loop over verified insights with reliability score -->
  </section>
  <section id="guide">
    <h2>{{ labels.guide }}</h2>
    <!-- TODO(V0): Safe / Caution / Avoid columns -->
  </section>
  <section id="action-plan">
    <h2>{{ labels.action_plan }}</h2>
    <!-- TODO(V0): 3-6 dated, executable moves -->
  </section>
  <section id="frontier-question">
    <h2>{{ labels.frontier_question }}</h2>
    <!-- TODO(V0): open question for the next Storm run -->
  </section>
</main>
<footer>Generated by StormGrill — verified facts, stress-tested decisions.</footer>
</body>
</html>
